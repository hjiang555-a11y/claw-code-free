# ─────────────────────────────────────────────────────────────────────────────
# claw-code-free — environment variable reference
#
# Copy this file to .env and fill in the values you need.
# Lines beginning with # are comments and are not read by the runtime.
#
# IMPORTANT: Never commit real credentials, API keys, or secrets to source
# control. This file contains only example placeholders.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic API credentials ─────────────────────────────────────────────────

# Your Anthropic API key. Required when using API-key authentication.
# Obtain one at https://console.anthropic.com/settings/keys
# Either ANTHROPIC_API_KEY or ANTHROPIC_AUTH_TOKEN must be set to call the API.
ANTHROPIC_API_KEY=your-api-key-here

# OAuth bearer token (alternative to ANTHROPIC_API_KEY).
# Set this instead of ANTHROPIC_API_KEY when using OAuth-based authentication
# (e.g. after running `claw login`). Do NOT set both at the same time.
# ANTHROPIC_AUTH_TOKEN=

# Override the Anthropic API base URL. Optional.
# Useful when pointing at a proxy, a local mock server, or a staging environment.
# Defaults to https://api.anthropic.com
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── Runtime paths ─────────────────────────────────────────────────────────────

# Override the directory where the Claw runtime stores credentials and config.
# Defaults to ~/.claude
# CLAUDE_CONFIG_HOME=~/.claude

# Override workspace-root detection for file-operation sandboxing.
# The runtime normally uses the current working directory.
# Set this only if you need to pin the sandbox root to a specific path.
# CLAWD_WORKSPACE_ROOT=/path/to/project-root

# ── Security / trust ─────────────────────────────────────────────────────────

# Set to "1" to allow the runtime to load hooks and MCP server extensions
# declared in the checked-in project config (.claude.json / .clawd.json).
# Off by default to protect against supply-chain attacks from untrusted repos.
# CLAWD_TRUST_PROJECT_EXTENSIONS=0

# ── Tool behaviour ────────────────────────────────────────────────────────────

# Set to "1" to allow the WebFetch tool to fetch private/intranet URLs
# that would otherwise be blocked. Off by default.
# CLAWD_ALLOW_PRIVATE_FETCH=0

# Override the base URL used by the WebSearch tool.
# Leave unset to use the default Anthropic search backend.
# CLAWD_WEB_SEARCH_BASE_URL=

# ── Sandbox ───────────────────────────────────────────────────────────────────

# Controls the filesystem sandbox mode.
# Valid values: "read-write" (default), "read-only"
# CLAWD_SANDBOX_FILESYSTEM_MODE=read-write

# Colon-separated list of additional paths the sandbox is allowed to mount/read.
# CLAWD_SANDBOX_ALLOWED_MOUNTS=

# ── Persistence (advanced) ───────────────────────────────────────────────────

# Override the path of the JSON file used by the Todo tool.
# Useful when running multiple isolated sessions in parallel.
# CLAWD_TODO_STORE=

# Override the directory used by the SubAgent tool for agent state.
# CLAWD_AGENT_STORE=
